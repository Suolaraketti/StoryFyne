# Required
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
# GEMINI_API_KEY falls back to GOOGLE_API_KEY if not set

# Required for R2 storage (Cloudflare REST API)
R2_ACCOUNT_ID=...
R2_API_TOKEN=...
R2_BUCKET_NAME=storyfyne
R2_PUBLIC_URL=https://your-account-id.r2.cloudflarestorage.com

# HeyGen AI (for AI influencer avatar video generation)
HEYGEN_API_KEY=...
HEYGEN_DEFAULT_AVATAR_ID=...

# Your app's public URL
# e.g. https://storyfyne-production.up.railway.app
PUBLIC_URL=

# Remotion Lambda / Render Gateway
RENDER_GATEWAY_URL=
REMOTION_SERVE_URL=https://remotionlambda-useast1-0x3rvofsis.s3.us-east-1.amazonaws.com/sites/u9yh9sqdi2/index.html
RENDER_GATEWAY_URL=https://your-gateway-service.up.railway.app
REMOTION_FPS=30
REMOTION_COMPOSITION_ID=ExplainerVideo

# Optional — Reddit API keys (only needed if you want PRAW scraping)
# If omitted, StoryFyne falls back to Reddit's public .json endpoint (no auth)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StoryFyne/1.0
