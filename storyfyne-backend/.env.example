# Required
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...

# Required for R2 storage
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=storyfyne-audio
R2_PUBLIC_URL=https://storyfyne.r2.cloudflarestorage.com

# Optional — Reddit API keys (only needed if you want PRAW scraping)
# If omitted, StoryFyne falls back to Reddit's public .json endpoint (no auth)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StoryFyne/1.0
